{
  "name": "@allshift/ui",
  "version": "0.3.0",
  "description": "Shift family shared FEEL layer — glass morphism, 3D tilt physics, holographic shine, scroll-triggered generation, and the living-canvas engine (LiveCard, LiveStat, CanvasTransition, CanvasLauncher). Brand-neutral by design.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "styles",
    "styles.css",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/shift-ui.css",
    "./canvas.css": "./styles/shift-canvas.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "framer-motion": ">=10",
    "react": ">=18",
    "lucide-react": ">=0.300.0",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "lucide-react": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shift",
    "design-system",
    "feel-layer",
    "glass-morphism",
    "framer-motion",
    "3d-tilt"
  ]
}
